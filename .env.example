# Base de datos.
# Desarrollo con PostgreSQL local (levantalo con: docker compose up -d):
DATABASE_URL=postgresql+asyncpg://ommadawn:ommadawn@localhost:5432/ommadawn
# Alternativa rapida sin instalar nada (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./ommadawn.db

# Clave para firmar los JWT. OBLIGATORIO cambiarla.
# Generar una con: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-random-secret-key

# Parametros de los tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
